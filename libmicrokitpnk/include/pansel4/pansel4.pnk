/@ method ffiouter_seL4_NBSendRecv(c: Int, c2: Int, a: Int, a2: Int)
   requires acc(heap[LIBSEL4_FFI_OFFSET])
   requires acc(heap[LIBSEL4_FFI_OFFSET+1])
   requires pansel4_has_cap(c2)
   requires pansel4_has_endpoint_cap(c2) || pansel4_has_notification_cap(c2)
   requires IsAbsMsgInfo(a2)
   requires pansel4_has_cap(heap[LIBSEL4_FFI_OFFSET])
   requires pansel4_has_endpoint_cap(heap[LIBSEL4_FFI_OFFSET]) || pansel4_has_notification_cap(heap[LIBSEL4_FFI_OFFSET])
   requires pansel4_has_cap(heap[LIBSEL4_FFI_OFFSET+1])
   requires pansel4_has_notification_cap(heap[LIBSEL4_FFI_OFFSET]) || pansel4_has_reply_cap(heap[LIBSEL4_FFI_OFFSET+1])
   ensures acc(heap[LIBSEL4_FFI_OFFSET])
   ensures IsAbsMsgInfo(heap[LIBSEL4_FFI_OFFSET])
   ensures acc(heap[LIBSEL4_FFI_OFFSET+1])
   ensures bounded64(heap[LIBSEL4_FFI_OFFSET+1])
@/
fun panseL4_Response panseL4_NBSendRecv(panseL4_CPtr dest, panseL4_MessageInfo_t msginfo, panseL4_CPtr src, panseL4_CPtr reply) {
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET+1]) @/
    /@ requires pansel4_has_cap(dest) @/
    /@ requires pansel4_has_endpoint_cap(dest) || pansel4_has_notification_cap(dest) @/
    /@ requires IsAbsMsgInfo(msginfo) @/
    /@ requires pansel4_has_cap(src) @/
    /@ requires pansel4_has_endpoint_cap(src) || pansel4_has_notification_cap(src) @/
    /@ requires pansel4_has_cap(reply) @/
    /@ requires pansel4_has_notification_cap(src) || pansel4_has_reply_cap(reply) @/
    /@ ensures IsAbsMsgInfo(panseL4_Response_tag(retval)) @/
    /@ ensures bounded64(panseL4_Response_badge(retval)) @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET+1]) @/
    st LIBSEL4_FFI_OFFSET, src;
    st LIBSEL4_FFI_OFFSET + 1*@biw, reply;
    @outer_seL4_NBSendRecv(0, dest, LIBSEL4_FFI_OFFSET, msginfo);
    var panseL4_Response ret = lds panseL4_Response LIBSEL4_FFI_OFFSET;
    return ret;
}

