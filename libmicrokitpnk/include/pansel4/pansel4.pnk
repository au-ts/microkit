}

/@ method ffiouter_seL4_Signal(c: Int, c2: Int, a: Int, a2: Int)
   requires pansel4_has_cap(a2)
   requires pansel4_has_endpoint_cap(a2) || pansel4_has_notification_cap(a2)
@/
fun panseL4_Signal(panseL4_CPtr dest) {
    /@ requires pansel4_has_cap(dest) @/
    /@ requires pansel4_has_endpoint_cap(dest) || pansel4_has_notification_cap(dest) @/
    @outer_seL4_Signal(0, 0, 0, dest);
    return 0;
}

