}

/@ method ffiouter_seL4_SetMR(c: Int, c2: Int, a: Int, a2: Int)
   requires 0 <= c2 && c2 < panseL4_MsgMaxLength
@/
fun panseL4_SetMR(1 mr, 1 value) {
    /@ requires 0 <= mr && mr < panseL4_MsgMaxLength @/
    @outer_seL4_SetMR(0, mr, 0, value);
    return 0;
}

/@ method ffiouter_seL4_GetMR(c: Int, c2: Int, a: Int, a2: Int)
   requires acc(heap[LIBSEL4_FFI_OFFSET])
   requires 0 <= a2 && a2 < panseL4_MsgMaxLength
