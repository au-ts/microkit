// Specialized version of panseL4_TCB_WriteRegisters for starting a thread at a
// given program counter value. TODO: write a proper implementation of
// panseL4_TCB_WriteRegisters(..) itself.
/@ method ffiouter_seL4_TCB_WriteRegisters_spec(c: Int, c2: Int, a: Int, a2: Int)
   requires acc(heap[LIBSEL4_FFI_OFFSET])
   requires pansel4_has_cap(c2)
   requires pansel4_has_tcb_cap(c2)
   ensures acc(heap[LIBSEL4_FFI_OFFSET])
   ensures bounded64(heap[LIBSEL4_FFI_OFFSET])
@/
fun panseL4_Error panseL4_TCB_WriteRegisters_spec(panseL4_TCB tcb, 1 entry_point) {
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ requires pansel4_has_cap(tcb) @/
    /@ requires pansel4_has_tcb_cap(tcb) @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET]) @/
    @outer_seL4_TCB_WriteRegisters_spec(0, tcb, LIBSEL4_FFI_OFFSET, entry_point);
    var ret = lds 1 LIBSEL4_FFI_OFFSET;
    return ret;
}

