/* TODO: Currently compatible with ARCH=riscv64 only! */

#define LIBSEL4_FFI_OFFSET @base
// requires 5*@biw space below this offset
// must be 8-byte aligned

#define panseL4_Bool 1

// TODO: replace with named struct once supported
#define panseL4_Response {1, 1}
#define panseL4_Response_tag(x) x.0
#define panseL4_Response_badge(x) x.1

#define panseL4_Word 1
#define panseL4_MessageInfo_t 1
#define panseL4_CPtr 1
#define panseL4_TCB 1

#define panseL4_Error 1
#define panseL4_NoError 0

#define panseL4_MsgMaxLength 120

// the following come from the AbsMsgInfo domain in spec.vpr
/@ extern function IsAbsMsgInfo(x: Int): Bool @/
/@ extern function label_of(x: Int): Int @/
/@ extern function capsUnwrapped_of(x: Int): Int @/
/@ extern function extraCaps_of(x: Int): Int @/
/@ extern function length_of(x: Int): Int @/
/@ extern function AbsMsgInfo_IRQAckIRQ(): Int @/

// the following come from the Microkit tool's CapDL export
/@ extern function pansel4_has_cap(x: Int): Bool @/
/@ extern function pansel4_has_endpoint_cap(x: Int): Bool @/
/@ extern function pansel4_has_notification_cap(x: Int): Bool @/
/@ extern function pansel4_has_reply_cap(x: Int): Bool @/
/@ extern function pansel4_has_page_table_cap(x: Int): Bool @/
/@ extern function pansel4_has_irq_handler_cap(x: Int): Bool @/
/@ extern function pansel4_has_tcb_cap(x: Int): Bool @/
/@ extern function pansel4_has_vcpu_cap(x: Int): Bool @/
/@ extern function pansel4_has_ioport_cap(x: Int): Bool @/
/@ extern function pansel4_has_arm_smc_cap(x: Int): Bool @/

/@ method ffiouter_seL4_MessageInfo_new(c: Int, c2: Int, a: Int, a2: Int)
   requires acc(heap[LIBSEL4_FFI_OFFSET])
   requires acc(heap[LIBSEL4_FFI_OFFSET+1])
   requires acc(heap[LIBSEL4_FFI_OFFSET+2])
   requires acc(heap[LIBSEL4_FFI_OFFSET+3])
   requires 0 <= heap[LIBSEL4_FFI_OFFSET] && heap[LIBSEL4_FFI_OFFSET] < 4503599627370496
   requires 0 <= heap[LIBSEL4_FFI_OFFSET+1] && heap[LIBSEL4_FFI_OFFSET+1] < 8
   requires 0 <= heap[LIBSEL4_FFI_OFFSET+2] && heap[LIBSEL4_FFI_OFFSET+2] < 4
   requires 0 <= heap[LIBSEL4_FFI_OFFSET+3] && heap[LIBSEL4_FFI_OFFSET+3] < 128
   ensures acc(heap[LIBSEL4_FFI_OFFSET])
   ensures acc(heap[LIBSEL4_FFI_OFFSET+1])
   ensures acc(heap[LIBSEL4_FFI_OFFSET+2])
   ensures acc(heap[LIBSEL4_FFI_OFFSET+3])
   ensures bounded64(heap[LIBSEL4_FFI_OFFSET])
   ensures IsAbsMsgInfo(heap[LIBSEL4_FFI_OFFSET])
   ensures label_of(heap[LIBSEL4_FFI_OFFSET]) == old(heap[LIBSEL4_FFI_OFFSET])
   ensures capsUnwrapped_of(heap[LIBSEL4_FFI_OFFSET]) == old(heap[LIBSEL4_FFI_OFFSET + 1])
   ensures extraCaps_of(heap[LIBSEL4_FFI_OFFSET]) == old(heap[LIBSEL4_FFI_OFFSET + 2])
   ensures length_of(heap[LIBSEL4_FFI_OFFSET]) == old(heap[LIBSEL4_FFI_OFFSET + 3])
@/
fun panseL4_MessageInfo_t panseL4_MessageInfo_new(1 label, 1 capsUnwrapped, 1 extraCaps, 1 length) {
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET+1]) @/
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET+2]) @/
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET+3]) @/
    /@ requires 0 <= label && label < 4503599627370496 @/
    /@ requires 0 <= capsUnwrapped && capsUnwrapped < 8 @/
    /@ requires 0 <= extraCaps && extraCaps < 4 @/
    /@ requires 0 <= length && length < 128 @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET]) && bounded64(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET+1]) @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET+2]) @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET+3]) @/
    /@ ensures IsAbsMsgInfo(retval) @/
    /@ ensures label_of(retval) == label @/
    /@ ensures capsUnwrapped_of(retval) == capsUnwrapped @/
    /@ ensures extraCaps_of(retval) == extraCaps @/
    /@ ensures length_of(retval) == length @/
    st LIBSEL4_FFI_OFFSET, label;
    st LIBSEL4_FFI_OFFSET + 1*@biw, capsUnwrapped;
    st LIBSEL4_FFI_OFFSET + 2*@biw, extraCaps;
    st LIBSEL4_FFI_OFFSET + 3*@biw, length;
    @outer_seL4_MessageInfo_new(0, 0, LIBSEL4_FFI_OFFSET, 0);
    var ret = lds 1 LIBSEL4_FFI_OFFSET;
    return ret;
}

/@ method ffiouter_seL4_MessageInfo_IRQAckIRQ(c: Int, c2: Int, a: Int, a2: Int)
   requires acc(heap[LIBSEL4_FFI_OFFSET])
   ensures acc(heap[LIBSEL4_FFI_OFFSET])
   ensures heap[LIBSEL4_FFI_OFFSET] == AbsMsgInfo_IRQAckIRQ()
@/
fun panseL4_MessageInfo_t panseL4_MessageInfo_IRQAckIRQ() {
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ ensures retval == AbsMsgInfo_IRQAckIRQ() @/
    @outer_seL4_MessageInfo_IRQAckIRQ(0, 0, LIBSEL4_FFI_OFFSET, 0);
    var ret = lds 1 LIBSEL4_FFI_OFFSET;
    return ret;
}

/@ method ffiouter_seL4_MessageInfo_get_label(c: Int, c2: Int, a: Int, a2: Int)
   requires IsAbsMsgInfo(a2)
   requires acc(heap[LIBSEL4_FFI_OFFSET])
   ensures acc(heap[LIBSEL4_FFI_OFFSET])
   ensures heap[LIBSEL4_FFI_OFFSET] == label_of(a2)
@/
fun 1 panseL4_MessageInfo_get_label(panseL4_MessageInfo_t msginfo) {
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ requires IsAbsMsgInfo(msginfo) @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ ensures retval == label_of(msginfo) @/
    @outer_seL4_MessageInfo_get_label(0, 0, LIBSEL4_FFI_OFFSET, msginfo);
    var ret = lds 1 LIBSEL4_FFI_OFFSET;
    return ret;
}

