/@ method ffiouter_seL4_Recv(c: Int, c2: Int, a: Int, a2: Int)
   requires acc(heap[LIBSEL4_FFI_OFFSET])
   requires acc(heap[LIBSEL4_FFI_OFFSET+1])
   requires pansel4_has_cap(c2)
   requires pansel4_has_endpoint_cap(c2) || pansel4_has_notification_cap(c2)
   requires pansel4_has_notification_cap(c2) || pansel4_has_cap(a2)
   requires pansel4_has_notification_cap(c2) || pansel4_has_reply_cap(a2)
   ensures acc(heap[LIBSEL4_FFI_OFFSET])
   ensures IsAbsMsgInfo(heap[LIBSEL4_FFI_OFFSET])
   ensures acc(heap[LIBSEL4_FFI_OFFSET+1])
   ensures bounded64(heap[LIBSEL4_FFI_OFFSET+1])
@/
fun panseL4_Response panseL4_Recv(panseL4_CPtr src, panseL4_CPtr reply) {
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ requires acc(heap[LIBSEL4_FFI_OFFSET+1]) @/
    /@ requires pansel4_has_cap(src) @/
    /@ requires pansel4_has_endpoint_cap(src) || pansel4_has_notification_cap(src) @/
    /@ requires pansel4_has_notification_cap(src) || pansel4_has_cap(reply) @/
    /@ requires pansel4_has_notification_cap(src) || pansel4_has_reply_cap(reply) @/
    /@ ensures IsAbsMsgInfo(panseL4_Response_tag(retval)) @/
    /@ ensures bounded64(panseL4_Response_badge(retval)) @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET]) @/
    /@ ensures acc(heap[LIBSEL4_FFI_OFFSET+1]) @/
    @outer_seL4_Recv(0, src, LIBSEL4_FFI_OFFSET, reply);
    var panseL4_Response ret = lds panseL4_Response LIBSEL4_FFI_OFFSET;
    return ret;
}

